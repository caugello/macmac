# {{ ansible_managed }}
# Environment for the MacMac remote enricher worker.
# Rendered by deploy/enricher-remote/playbook.yml from Ansible vars/vault.
# Secrets live in group_vars/all/vault.yml (vault-encrypted) — never committed;
# non-secret config in group_vars/all/vars.yml.
#
# NOTE: the worker is DB-free. CATALOG_DATABASE_URL is intentionally NOT set —
# the enricher consumes from RabbitMQ and publishes results back; snitch (central)
# is the only component that touches Postgres.

# OpenAI key for the GPT-4o-mini enrichment calls.
OPENAI_API_KEY={{ openai_api_key }}

# Central RabbitMQ over TLS. Per-location, least-privilege credentials.
# Format: amqps://USER:PASS@HOST:5671/VHOST
RABBITMQ_URL={{ rabbitmq_url }}

# CA bundle used to verify the RabbitMQ server certificate (mounted read-only).
RABBITMQ_CA_CERT_PATH={{ rabbitmq_ca_cert_container_path }}

{% if rabbitmq_tls_server_name | default('') | length > 0 %}
# Override the SNI / cert hostname when it differs from the URL host
# (e.g. connecting via an OpenShift Route with TLS passthrough).
RABBITMQ_TLS_SERVER_NAME={{ rabbitmq_tls_server_name }}
{% else %}
# Optional: override the SNI / cert hostname when it differs from the URL host.
# RABBITMQ_TLS_SERVER_NAME=rabbitmq.example.com
{% endif %}
# Stamps which location enriched each item (logs/results).
WORKER_LOCATION={{ worker_location }}

{% if enricher_forward_proxy | default('') | length > 0 %}
# Per-worker static ISP/residential forward proxy (residential-classified egress
# so collectandgo's Fastly bot-management returns 200 instead of 456).
# Format: http://USER:PASS@HOST:PORT
ENRICHER_FORWARD_PROXY={{ enricher_forward_proxy }}
{% else %}
# Per-worker static ISP/residential forward proxy. Set per host (different IP each).
# ENRICHER_FORWARD_PROXY=http://USER:PASS@host:port
{% endif %}
