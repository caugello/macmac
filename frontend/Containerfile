# Build stage
FROM --platform=$BUILDPLATFORM node:24-alpine@sha256:2bdb65ed1dab192432bc31c95f94155ca5ad7fc1392fb7eb7526ab682fa5bf14 AS build

WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build

# Production stage (hi/nginx distroless — no shell, no package manager)
FROM registry.access.redhat.com/hi/nginx:1.28@sha256:6174f18fe74728fca3b281993e71d804338daa2116425eb210bc143e087ccddc

COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/nginx.conf

EXPOSE 8080
CMD ["nginx", "-g", "daemon off;"]
