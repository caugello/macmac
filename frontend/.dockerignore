# Build context excludes for the frontend image.
# Keeps host-only artifacts out of `COPY . .` so the build stage installs a
# clean, platform-correct dependency tree via `npm ci` and ships a smaller,
# lower-attack-surface layer.
#
# NOTE: package*.json is intentionally NOT ignored — `npm ci` needs
# package-lock.json from the build context.

# Dependencies (reinstalled in-image by `npm ci`; host copy is wrong-arch)
node_modules

# Build / tooling output (regenerated by `npm run build`)
dist
build
.vite

# Test coverage and test sources (not needed by the production build)
coverage
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
src/test
vitest.config.ts
vitest.polyfill.js

# Local environment and logs
.env
.env.*
*.log

# Container build files and docs (not part of the served app)
Containerfile
.containerignore
.dockerignore
README.md
