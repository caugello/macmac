# MacMac Environment Variables - SECRETS ONLY
# Copy this file to .env and update with your actual secrets
#
# IMPORTANT: This file contains ONLY secrets (passwords, keys, tokens).
# Configuration settings (timeouts, TTLs, URLs, etc.) are in config.yaml
# which is committed to git and safe to share.
#
# ==============================================================================
# CRITICAL SECURITY - REQUIRED IN PRODUCTION
# ==============================================================================

# JWT Secret Key - MUST be a random 32+ character string in production
# Generate with: openssl rand -hex 32
# This is used to sign authentication tokens - NEVER commit the real value
JWT_SECRET_KEY=your-super-secret-jwt-key-min-32-chars-change-in-production

# Environment (development|staging|production)
# Affects security validation and default behaviors
ENVIRONMENT=development

# ==============================================================================
# DATABASE PASSWORDS - Required for database access
# ==============================================================================
# Format: postgresql+psycopg2://USER:PASSWORD@HOST:PORT/DATABASE
# Connection structure (host, port, database name) is in config.yaml
# Only the passwords are secret and must be here

# Auth Service Database
AUTH_DATABASE_URL=postgresql+psycopg2://dbuser:dbpass@localhost:5435/auth

# Recipes Service Database
RECIPES_DATABASE_URL=postgresql+psycopg2://dbuser:dbpass@localhost:5432/recipes

# Catalog Service Database
CATALOG_DATABASE_URL=postgresql+psycopg2://dbuser:dbpass@localhost:5433/catalog

# Meal Plans Service Database
MEAL_PLANS_DATABASE_URL=postgresql+psycopg2://dbuser:dbpass@localhost:5434/meal_plans

# ==============================================================================
# AUTHENTICATION SECRETS
# ==============================================================================

# Keycloak Client Secret - Required for OAuth flows
# Public settings (URL, realm, client_id) are in config.yaml
KEYCLOAK_CLIENT_SECRET=macmac-api-secret

# ==============================================================================
# REDIS CONFIGURATION (Optional Overrides)
# ==============================================================================

# MacMac runs exclusively in containers with Redis configured in config.yaml:
#   host: redis (container service name)
#   port: 6379
#   db: 0
#
# These environment variables are ONLY needed if you're using a non-standard Redis setup:
# - External Redis instance
# - Different port or database number
# - Redis with authentication enabled

# Redis Host - Override if using external Redis (default: redis from config.yaml)
# REDIS_HOST=external-redis.example.com

# Redis Port - Override if using non-standard port (default: 6379 from config.yaml)
# REDIS_PORT=6380

# Redis Database Number - Override if needed (default: 0 from config.yaml)
# REDIS_DB=1

# Redis Password - Required only if Redis has authentication enabled
# REDIS_PASSWORD=your-redis-password

# ==============================================================================
# EXTERNAL API KEYS
# ==============================================================================

# OpenAI API Key - Required for catalog enrichment
# The model name is configured in config.yaml, only the key is secret
OPENAI_API_KEY=sk-your-openai-api-key-here
